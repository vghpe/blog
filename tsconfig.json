{
  "compilerOptions": {
    "target": "ES2018",
    "module": "none",
    "lib": ["DOM", "ES2018"],
    "strict": true,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "outFile": "static/games/jamble/jamble.js"
  },
  "files": [
    "static/games/jamble/constants.ts",
    "static/games/jamble/countdown.ts",
    "static/games/jamble/obstacle.ts",
    "static/games/jamble/wiggle.ts",
    "static/games/jamble/player.ts",
    "static/games/jamble/game.ts",
    "static/games/jamble/boot.ts"
  ]
}
